# Database / auth (existing project vars)
DATABASE_URL=mysql://usuario:password@localhost:3306/tu_bd
JWT_SECRET=reemplaza-por-un-secreto-largo
VITE_APP_ID=tu_app_id
OAUTH_SERVER_URL=http://localhost:8080

# SMTP configuration for room-reservation emails
# Required by server/_core/index.ts endpoint: POST /api/salas/reservas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_o_clave_smtp
SMTP_FROM="CID Reservas <tu_correo@gmail.com>"

# IA local gratuita (recomendado)
# Opciones: ollama | gemini | forge
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-r1:1.5b

# IA remota opcional (solo si quieres usar APIs pagas o gratuitas con cuota)
# GEMINI_API_KEY=
# BUILT_IN_FORGE_API_KEY=
# BUILT_IN_FORGE_API_URL=https://forge.manus.im

